digraph EsquemaInstagentrificacion {
  rankdir=TB;
  newrank=true;
  splines=polyline;
  nodesep=0.22;
  ranksep=0.42;
  overlap=false;

  graph [fontname="Helvetica", pad="0.12", bgcolor="white"];
  node  [fontname="Helvetica", shape=box, style="rounded,filled", color="black", fillcolor="white", fontsize=9, margin="0.11,0.06"];
  edge  [fontname="Helvetica", color="black", fontsize=8, penwidth=1.2];

  A1 [label="CE local\n(memoria, oficios, comunidad)", group="g1"];
  A2 [label="Legibilidad de plataforma\n(fotogenia, relato breve,\nrepetibilidad)", group="g2"];
  A3 [label="VE circulable\n(imagen de destino,\natención)", group="g3"];
  A4 [label="Intervención material\n(decisiones urbanas,\njurídicas y económicas)", group="g4"];
  A5 [label="Resultado\n(desplazamiento y beneficios\nen intermediarios)", group="g5"];

  B1 [label="Tasa más desfavorable:\nel CE local no captura el VE", group="g3"];
  B2 [label="Marcos externos\nordenan el territorio", group="g4"];
  B3 [label="Forma circulable >\nnegatividad crítica", group="g5"];

  { rank=same; A1; A2; A3; A4; A5; }
  { rank=same; B1; B2; B3; }

  A1 -> A2 [label="selección", constraint=false];
  A2 -> A3 [label="traducción", constraint=false];
  A3 -> A4 [label="se implementa en", constraint=false];
  A4 -> A5 [label="produce", constraint=false];

  A3 -> B1 [style=dashed, arrowhead=none];
  A4 -> B2 [style=dashed, arrowhead=none];
  A5 -> B3 [style=dashed, arrowhead=none];

  B1 -> B2 [style=invis, weight=20];
  B2 -> B3 [style=invis, weight=20];
}
